# Source PACS — must match a modality name configured in Orthanc
SOURCE_MODALITY=SOURCE_PACS

# Orthanc (destination) — leave USERNAME/PASSWORD empty if auth is disabled
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=
ORTHANC_PASSWORD=
DEST_AET=DEST_ORTHANC

# Migration behaviour
BATCH_SIZE=10
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2
RETRY_BACKOFF_MAX=60
QUERY_TIMEOUT=600

# Tracking database path (inside container, mount as volume)
DB_PATH=data/migration.db

# Optional: restrict discovery to a date range (YYYYMMDD)
DATE_FROM=
DATE_TO=
